# OrganizationLaunchpad Environment Variables
# Copy to `.env` or `.env.local` (never commit real secrets).

# =============================================================================
# SUPABASE - Auth, Postgres, Storage, Edge Functions
# =============================================================================
# Get from: https://supabase.com/dashboard → Project Settings → API
# Project URL and anon key are safe for browser use (RLS enforces security).
# Service role key is a server-side secret that bypasses RLS.

VITE_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
VITE_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-only secret - never expose to frontend or commit to version control.
# Used in: Supabase Edge Functions, Row Level Security
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# CLOUDFLARE - Pages (Frontend Hosting), DNS
# =============================================================================
# Get API token from: https://dash.cloudflare.com/profile/api-tokens
# Create a custom token with minimal permissions (e.g., Zone DNS Edit, Zone Read).

CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Get Account ID from: Cloudflare dashboard → Workers & Pages → Overview → Account ID
# Used by: Terraform, Wrangler CLI
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# =============================================================================
# RESEND - Email Delivery
# =============================================================================
# Get from: https://resend.com/api-keys
# Used for transactional emails (welcome, password reset, etc.).

RESEND_API_KEY=re_your-resend-api-key

# =============================================================================
# STRIPE - Payments
# =============================================================================
# Get from: https://dashboard.stripe.com/apikeys
# Use test keys (pk_test_*/sk_test_*) during development.

STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# =============================================================================
# POSTHOG - Error tracking and analytics
# =============================================================================
# Get from: https://posthog.com → Settings → Projects → API
# Used for: error tracking, session replay, product analytics.

VITE_POSTHOG_API_KEY=phc_your-api-key
VITE_POSTHOG_HOST=https://app.posthog.com
