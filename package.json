{
  "name": "organization-launchpad",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev:web": "npm run dev -w web",
    "build:web": "npm run build -w web",
    "tauri:dev": "npm run tauri:dev -w web",
    "tauri:build": "npm run tauri:build -w web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
