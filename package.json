    "test": "npm run test -w web",
    "test:e2e": "npm run test:e2e -w web",
    "test:coverage": "npm run test:coverage -w web",
    "deploy:edge": "supabase functions deploy",
    "serve:edge": "supabase functions serve"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.0"
  }
}
