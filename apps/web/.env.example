# Copy to .env.local (never commit .env.local to git)

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project Settings → API
VITE_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
VITE_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Stripe ───────────────────────────────────────────────────────────────────
# Dashboard → Product catalog → (your product) → Price ID
VITE_PUBLIC_STRIPE_PRICE_ID=price_...

# ── PostHog ──────────────────────────────────────────────────────────────────
# Project Settings → Project API key
VITE_PUBLIC_POSTHOG_KEY=phc_...
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Local dev worker ─────────────────────────────────────────────────────────
VITE_PUBLIC_API_URL=http://127.0.0.1:8787
